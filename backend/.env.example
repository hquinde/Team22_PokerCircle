# =============================================================
# PokerCircle Backend — Environment Variables
# Copy this file to .env and fill in real values locally.
# On Railway, set these via the Railway dashboard — never commit .env.
# =============================================================

# Supabase connection string (URI mode).
# Find it at: Supabase dashboard → Settings → Database → Connection String → URI
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Long random string used to sign session cookies.
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=replace-me-with-a-long-random-secret

# Railway injects PORT automatically. Leave as 3000 for local dev.
PORT=3000

# Set to "production" in Railway dashboard, "development" locally.
NODE_ENV=development

# Comma-separated allowed frontend origins.
WEB_ORIGIN=http://localhost:8081